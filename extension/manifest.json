{
  "manifest_version": 3,
  "name": "InspireHub 剪藏",
  "version": "1.0.0",
  "description": "一键保存灵感到 InspireHub — 支持链接/图片/代码/笔记",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "保存到 InspireHub"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html"
}
